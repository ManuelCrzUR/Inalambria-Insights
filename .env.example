# .env.example
# Copia este archivo como .env y ajusta los valores a tu entorno local.
# El archivo .env NUNCA debe commitearse (ya está en .gitignore).

# Rutas de datos
DATA_DIR=./data
OUTPUT_DIR=./output
PARQUET_FILENAME=sms.parquet

# Logging
LOG_LEVEL=INFO

# Rendimiento
CHUNK_SIZE=50000
MAX_MEMORY_MB=500

# Pipeline
DELIVERED_ONLY=true
REDIS_THRESHOLD=50
REDIS_TTL_DAYS=90

# Classificador (LLM Panel + Árbitro)
OPENAI_API_KEY=sk-your-key-here
MODEL_PANEL_1=gpt-4o-mini
MODEL_PANEL_2=gpt-5-nano
MODEL_ARBITER=gpt-5.4
CLASSIFIER_AGREEMENT_THRESHOLD=0.7
CLASSIFIER_CONCURRENCY=10
TAXONOMY_PATH=config/taxonomy.json
CLASSIFICATIONS_OUTPUT_FILENAME=classifications.jsonl
