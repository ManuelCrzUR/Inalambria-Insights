# .env.example
# Copia este archivo como .env y ajusta los valores a tu entorno local.
# El archivo .env NUNCA debe commitearse (ya está en .gitignore).

# Rutas de datos
DATA_DIR=./data
OUTPUT_DIR=./output
PARQUET_FILENAME=sms.parquet

# Logging
LOG_LEVEL=INFO

# Rendimiento
CHUNK_SIZE=50000
MAX_MEMORY_MB=500

# Pipeline
DELIVERED_ONLY=true
REDIS_THRESHOLD=50
REDIS_TTL_DAYS=90
